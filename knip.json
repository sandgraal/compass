{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "electron/main.ts",
    "electron/preload.ts",
    "electron/preload-quick-capture.ts",
    "src/main.tsx",
    "src/App.tsx",
    "src/quickCapture/main.tsx",
    "scripts/*.ts",
    "electron.vite.config.ts",
    "tailwind.config.ts",
    "vitest.config.ts",
    "playwright.config.ts"
  ],
  "project": ["src/**/*.{ts,tsx}", "electron/**/*.ts", "scripts/**/*.ts"],
  "ignore": [
    "knowledge-base/**",
    ".vault/**",
    ".data/**",
    "dist/**",
    "dist-electron/**",
    "out/**",
    "release/**",
    "**/*.d.ts"
  ],
  "ignoreBinaries": ["mktemp"]
}
