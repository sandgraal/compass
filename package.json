{
  "name": "compass",
  "version": "0.6.0",
  "description": "A local-first personal life planning OS",
  "main": "out/main/main.js",
  "author": {
    "name": "sandgraal",
    "email": "92229510+sandgraal@users.noreply.github.com"
  },
  "license": "UNLICENSED",
  "private": true,
  "workspaces": ["mcp/compass-mcp"],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder",
    "release": "npm run build && electron-builder --publish always",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx electron/db/migrate.ts",
    "typecheck": "tsc -p tsconfig.web.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "check": "biome check --error-on-warnings .",
    "format": "biome check --write .",
    "lint:fast": "oxlint .",
    "lint:react": "eslint src",
    "test": "vitest --passWithNoTests",
    "test:run": "vitest --run --passWithNoTests",
    "test:coverage": "vitest --run --coverage --passWithNoTests",
    "test:e2e": "playwright test --pass-with-no-tests",
    "screenshots": "npm rebuild better-sqlite3 && DEMO_HOME=\"$(mktemp -d)\" && COMPASS_SEED_DEMO=1 COMPASS_HOME=\"$DEMO_HOME\" tsx scripts/seed-demo.ts && npm run build && electron-builder install-app-deps && COMPASS_DEMO_HOME=\"$DEMO_HOME\" playwright test e2e/screenshots.e2e.ts; CODE=$?; npm rebuild better-sqlite3; exit $CODE",
    "knip": "knip",
    "status": "tsx scripts/project-status.ts",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.1",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-collapsible": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.2.1",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@tiptap/extension-link": "^2.10.4",
    "@tiptap/extension-placeholder": "^2.10.4",
    "@tiptap/extension-task-item": "^2.10.4",
    "@tiptap/extension-task-list": "^2.10.4",
    "@tiptap/extension-typography": "^2.10.4",
    "@tiptap/pm": "^2.10.4",
    "@tiptap/react": "^2.10.4",
    "@tiptap/starter-kit": "^2.10.4",
    "better-sqlite3": "^12.9.0",
    "chokidar": "^4.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "googleapis": "^144.0.0",
    "lucide-react": "^0.462.0",
    "node-cron": "^3.0.3",
    "pdf-parse": "^2.4.5",
    "plaid": "^42.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^6.4.2",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@playwright/test": "^1.49.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.1",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.5.0",
    "electron-builder": "^26.9.0",
    "electron-playwright-helpers": "^1.7.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "knip": "^5.39.4",
    "lefthook": "^1.10.10",
    "oxlint": "^0.15.0",
    "playwright": "^1.49.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "vite": "$vite"
  },
  "engines": {
    "node": ">=20.16.0"
  },
  "build": {
    "appId": "com.compass.app",
    "productName": "Compass",
    "publish": {
      "provider": "github",
      "owner": "sandgraal",
      "repo": "compass",
      "releaseType": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "resources/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        },
        {
          "target": "zip",
          "arch": ["arm64", "x64"]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "linux": {
      "category": "Utility",
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "deb",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "protocols": [
      {
        "name": "Compass URL",
        "schemes": ["compass"]
      }
    ],
    "files": ["out/**/*", "package.json"],
    "asarUnpack": ["**/*.node"],
    "directories": {
      "output": "release"
    }
  }
}
